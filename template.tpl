___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const query = require('getQueryParameters');
const setCookie = require('setCookie');
const log = require('logToConsole');

const debug = data.debug;

// Get clid from URL
const clid = query('clid');

if (clid) {

  setCookie('influise_clid', clid, {
    'max-age': 31536000,
    path: '/',
    samesite: 'Lax'
  });

  if (debug) {
    log('Influise: Stored clickId', clid);
  }
}

data.gtmOnSuccess();


